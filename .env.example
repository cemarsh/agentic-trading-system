# Alpaca Markets
ALPACA_KEY=your_alpaca_api_key
ALPACA_SECRET=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # Switch to https://api.alpaca.markets for live

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/trading

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
ALERT_EMAIL=you@yourdomain.com

# Claude AI (Strategy Advisor — weekly scan, lessons digest)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Timezone
MARKET_TIMEZONE=America/New_York

# NotebookLM Trading Intelligence Bridge (n8n workflow)
# Supabase project for trading signals (can reuse existing or create dedicated)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key
# Webhook secret for research intake endpoint (generate: openssl rand -hex 32)
WEBHOOK_SECRET=your_webhook_secret
# Optional: Slack webhook for high-conviction signal alerts (conviction >= 7)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# Optional: Google Drive folder ID for NotebookLM export polling (Path B)
GOOGLE_DOCS_FOLDER_ID=your_google_drive_folder_id

